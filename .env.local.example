# ─────────────────────────────────────────────────────────────
# .env.local.example
# cp .env.local.example .env.local 후 값을 채워주세요.
# .env.local 은 절대 Git에 커밋하지 마세요 (.gitignore 확인).
# ─────────────────────────────────────────────────────────────

# Supabase ─ 대시보드 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 관리자 비밀번호 (/admin 페이지 + /api/admin 보호)
ADMIN_PASSWORD=your-secret-admin-password

# Cloudflare Turnstile ─ https://dash.cloudflare.com → Turnstile
# 비워두면 로컬 개발 시 캡차 검증이 자동으로 생략됩니다.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxx
